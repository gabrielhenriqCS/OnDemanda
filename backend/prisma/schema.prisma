generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model comanda {
  id           Int            @id @default(autoincrement())
  cliente      String?
  mesaId       Int
  status       comanda_status @default(ABERTA)
  criadoEm     DateTime       @default(now())
  atualizadoEm DateTime
  mesa         mesa           @relation(fields: [mesaId], references: [id], map: "Comanda_mesaId_fkey")
  pedido       pedido[]

  @@index([mesaId], map: "Comanda_mesaId_fkey")
}

model itempedido {
  id            Int     @id @default(autoincrement())
  pedidoId      Int
  produtoId     Int
  quantidade    Int
  observacao    String?
  precoUnitario Float
  precoTotal    Float
  pedido        pedido  @relation(fields: [pedidoId], references: [id], map: "ItemPedido_pedidoId_fkey")
  produto       produto @relation(fields: [produtoId], references: [id], map: "ItemPedido_produtoId_fkey")

  @@index([pedidoId], map: "ItemPedido_pedidoId_fkey")
  @@index([produtoId], map: "ItemPedido_produtoId_fkey")
}

model mesa {
  id           Int         @id @default(autoincrement())
  status       mesa_status @default(LIVRE)
  criadoEm     DateTime    @default(now())
  atualizadoEm DateTime
  cliente      String?
  mesa         Int
  comanda      comanda[]
}

model pedido {
  id           Int           @id @default(autoincrement())
  comandaId    Int
  status       pedido_status @default(PREPARANDO)
  criadoEm     DateTime      @default(now())
  atualizadoEm DateTime
  itempedido   itempedido[]
  comanda      comanda       @relation(fields: [comandaId], references: [id], map: "Pedido_comandaId_fkey")

  @@index([comandaId], map: "Pedido_comandaId_fkey")
}

model produto {
  id           Int          @id @default(autoincrement())
  nome         String
  descricao    String?
  preco        Float
  categoria    String?
  criadoEm     DateTime     @default(now())
  atualizadoEm DateTime
  itempedido   itempedido[]
}

model usuario {
  id     Int            @id @default(autoincrement())
  nome   String
  email  String         @unique(map: "Usuario_email_key")
  senha  String
  funcao usuario_funcao
}

enum mesa_status {
  OCUPADA
  LIVRE
}

enum pedido_status {
  PREPARANDO
  PRONTO
  ENTREGUE
}

enum comanda_status {
  ABERTA
  FECHADA
}

enum usuario_funcao {
  ADMIN
  GARCOM
  ATENDENTE
}
