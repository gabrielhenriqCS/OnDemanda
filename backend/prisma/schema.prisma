// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  funcao    usuario_funcao
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comanda {
  id        String   @id @default(uuid())
  cliente   String?
  mesaId    String
  status    comanda_status
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  mesa Mesa @relation(fields: [mesaId], references: [id], map: "fk_comanda_mesa")
  pedido Pedido[]

}

model Mesa {
  id        String   @id @default(uuid())
  numero    Int      @unique
  status    mesa_status
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cliente   String?
  mesas     Int
  comandas Comanda[]
}

model Pedido {
  id           Int           @id @default(autoincrement())
  comandaId    String
  status       pedido_status @default(PREPARANDO)
  criadoEm     DateTime      @default(now())
  atualizadoEm DateTime
  itempedido   Item_Pedido[]
  comanda      Comanda       @relation(fields: [comandaId], references: [id], map: "Pedido_comandaId_fkey")
}

model Produto {
  id           Int          @id @default(autoincrement())
  nome         String
  descricao    String?
  preco        Float
  categoria    String?
  criadoEm     DateTime     @default(now())
  atualizadoEm DateTime
  itempedido   Item_Pedido[]
}

model Item_Pedido {
  id            Int     @id @default(autoincrement())
  pedidoId      Int
  produtoId     Int
  quantidade    Int
  observacao    String?
  precoUnitario Float
  precoTotal    Float
  pedido        Pedido  @relation(fields: [pedidoId], references: [id], map: "ItemPedido_pedidoId_fkey")
  produto       Produto @relation(fields: [produtoId], references: [id], map: "ItemPedido_produtoId_fkey")
}

enum mesa_status {
  OCUPADA
  LIVRE
}

enum pedido_status {
  PREPARANDO
  PRONTO
  ENTREGUE
}

enum comanda_status {
  ABERTA
  FECHADA
}


enum usuario_funcao {
  ADMIN
  GARCOM
  ATENDENTE
}